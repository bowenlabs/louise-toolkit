---
// Bespoke hero section — the SITE owns this design (Tailwind + daisyUI, the real
// brand look). It renders from structured section props; editors never touch its
// markup or classes, only its fields (heading/tagline/cta). This is how a
// preconfigured block keeps a pixel-perfect bespoke design while staying
// editor-controlled.
import louiseMark from "../assets/louise-mark.svg?raw";

interface Props {
  heading?: string;
  tagline?: string;
  ctaLabel?: string;
  ctaHref?: string;
}
const { heading = "Louise CMS", tagline = "", ctaLabel, ctaHref } = Astro.props;
---

<section class="louise-type px-5 pt-24 pb-12 text-center">
  <div
    class="mx-auto mb-6 h-[68px] w-[68px] drop-shadow-lg [&>svg]:h-full [&>svg]:w-full"
    aria-hidden="true"
    set:html={louiseMark}
  />
  <h1 class="mb-3 text-5xl leading-none font-black tracking-tight md:text-6xl">{heading}</h1>
  {tagline && <p class="mx-auto mb-8 max-w-xl text-xl text-base-content/70">{tagline}</p>}
  {
    ctaLabel && ctaHref && (
      <a class="btn btn-primary" href={ctaHref}>
        {ctaLabel}
      </a>
    )
  }
</section>
