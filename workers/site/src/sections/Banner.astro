---
// Bespoke banner section — a full-width call-to-action strip (site-owned design,
// Tailwind + daisyUI). Renders from structured props; editors edit the copy in
// place and the button link in the dock. Mirrors Hero's edit-mode conventions:
// visible text nodes carry `data-louise-sfield` markers and always render (even
// when empty) so there's something to click into. `ctaHref` has no visible text,
// so it's edited in the dock, not here.
interface Props {
  heading?: string;
  body?: string;
  ctaLabel?: string;
  ctaHref?: string;
  _editIndex?: number;
  _editMode?: boolean;
}
const {
  heading = "",
  body = "",
  ctaLabel = "",
  ctaHref = "",
  _editIndex = 0,
  _editMode: edit = false,
} = Astro.props;
const idx = _editIndex;
---

<section class="px-5 pb-16">
  <div
    class="rounded-box bg-primary text-primary-content flex flex-col items-center gap-6 px-8 py-12 text-center md:flex-row md:justify-between md:text-left"
  >
    <div class="max-w-2xl">
      <h2
        class="text-3xl font-black tracking-tight md:text-4xl"
        data-louise-sfield={edit ? `${idx}.heading` : undefined}
      >
        {heading || (edit ? "" : "Ready to get started?")}
      </h2>
      {
        (edit || body) && (
          <p
            class="mt-2 text-lg text-primary-content/80"
            data-louise-sfield={edit ? `${idx}.body` : undefined}
            data-louise-multiline={edit || undefined}
          >
            {body}
          </p>
        )
      }
    </div>
    {
      (edit || (ctaLabel && ctaHref)) && (
        <a
          class="btn btn-lg shrink-0"
          href={ctaHref || "#"}
          data-louise-sfield={edit ? `${idx}.ctaLabel` : undefined}
        >
          {ctaLabel}
        </a>
      )
    }
  </div>
</section>
