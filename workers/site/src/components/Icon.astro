---
// Inline SVG icon. Takes a raw Phosphor SVG string (see ../lib/landing-icons.ts)
// and renders it so it inherits `currentColor` and sizes to 1em — set the size
// with a `text-[…]` utility and the color with a `text-*` utility on the call
// site. Decorative by default (aria-hidden); pass a `label` to expose it.
interface Props {
  svg: string;
  class?: string;
  label?: string;
}
const { svg, class: cls = "", label } = Astro.props;
---

<span
  class:list={["lt-icon", cls]}
  aria-hidden={label ? undefined : "true"}
  role={label ? "img" : undefined}
  aria-label={label}
  set:html={svg}
></span>
